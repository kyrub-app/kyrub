    // --- Public Marketplace Listings ---
    match /marketplace_listings/{listingId} {
      function isMarketplaceListingOwner(data) {
        return isSignedIn()
          && data.ownerId == request.auth.uid
          && data.storeId == request.auth.uid;
      }

      function hasValidMarketplaceStoreListingId(data) {
        return data.listingType == 'store'
          && listingId
            == 's_'
              + string(data.storeId.size())
              + '_'
              + data.storeId;
      }

      function hasValidMarketplaceOfferListingId(data) {
        return data.listingType == 'offer'
          && data.offerId is string
          && isValidId(data.offerId)
          && listingId
            == 'o_'
              + string(data.storeId.size())
              + '_'
              + data.storeId
              + '_'
              + string(data.offerId.size())
              + '_'
              + data.offerId;
      }

      function hasValidMarketplaceListingId(data) {
        return data.listingId == listingId
          && (
            hasValidMarketplaceStoreListingId(data)
            || hasValidMarketplaceOfferListingId(data)
          );
      }

      function hasValidMarketplaceBaseTypes(data) {
        return data.listingId is string
          && isValidId(data.listingId)
          && data.listingType is string
          && data.listingType in ['store', 'offer']
          && data.ownerId is string
          && isValidId(data.ownerId)
          && data.storeId is string
          && isValidId(data.storeId)
          && data.ownerId == data.storeId
          && data.publicationStatus is string
          && data.publicationStatus in [
            'draft',
            'published',
            'paused'
          ]
          && data.createdAt is timestamp
          && data.updatedAt is timestamp
          && (
            !data.keys().hasAny(['publishedAt'])
            || data.publishedAt is timestamp
          )
          && hasValidMarketplaceListingId(data);
      }

      function hasValidMarketplaceStoreKeys(data) {
        return data.keys().hasAll([
          'listingId',
          'listingType',
          'ownerId',
          'storeId',
          'name',
          'slug',
          'description',
          'address',
          'logo',
          'banner',
          'primaryColor',
          'keywords',
          'status',
          'publicationStatus',
          'createdAt',
          'updatedAt'
        ]) && data.keys().hasOnly([
          'listingId',
          'listingType',
          'ownerId',
          'storeId',
          'name',
          'slug',
          'description',
          'address',
          'logo',
          'banner',
          'primaryColor',
          'keywords',
          'status',
          'publicationStatus',
          'createdAt',
          'updatedAt',
          'publishedAt',
          'geoPosition'
        ]);
      }

      function hasValidMarketplaceOfferKeys(data) {
        return data.keys().hasAll([
          'listingId',
          'listingType',
          'ownerId',
          'storeId',
          'offerId',
          'name',
          'description',
          'price',
          'imageUrls',
          'stock',
          'isService',
          'category',
          'publicationStatus',
          'createdAt',
          'updatedAt'
        ]) && data.keys().hasOnly([
          'listingId',
          'listingType',
          'ownerId',
          'storeId',
          'offerId',
          'name',
          'description',
          'price',
          'imageUrls',
          'stock',
          'isService',
          'category',
          'publicationStatus',
          'createdAt',
          'updatedAt',
          'publishedAt'
        ]);
      }

      function hasValidMarketplaceListingKeys(data) {
        return (
          data.listingType == 'store'
          && hasValidMarketplaceStoreKeys(data)
        ) || (
          data.listingType == 'offer'
          && hasValidMarketplaceOfferKeys(data)
        );
      }

      function hasValidMarketplaceStoreTypes(data) {
        return data.name is string
          && data.name.size() >= 1
          && data.name.size() <= 120
          && data.slug is string
          && data.slug.size() <= 120
          && data.description is string
          && data.description.size() <= 2000
          && data.address is string
          && data.address.size() >= 1
          && data.address.size() <= 500
          && data.logo is string
          && data.logo.size() <= 2048
          && data.banner is string
          && data.banner.size() <= 2048
          && data.primaryColor is string
          && data.primaryColor.size() <= 32
          && data.keywords is list
          && data.keywords.size() <= 30
          && data.status is string
          && data.status in ['open', 'delayed', 'closed']
          && (
            !data.keys().hasAny(['geoPosition'])
            || data.geoPosition is latlng
          );
      }

      function hasValidMarketplaceOfferTypes(data) {
        return data.offerId is string
          && isValidId(data.offerId)
          && data.name is string
          && data.name.size() >= 1
          && data.name.size() <= 160
          && data.description is string
          && data.description.size() <= 4000
          && data.price is number
          && data.price >= 0
          && data.imageUrls is list
          && data.imageUrls.size() <= 12
          && data.stock is int
          && data.stock >= 0
          && data.isService is bool
          && data.category is string
          && data.category.size() <= 120;
      }

      function hasValidMarketplaceListingTypes(data) {
        return hasValidMarketplaceBaseTypes(data)
          && (
            (
              data.listingType == 'store'
              && hasValidMarketplaceStoreTypes(data)
            ) || (
              data.listingType == 'offer'
              && hasValidMarketplaceOfferTypes(data)
            )
          );
      }

      function hasValidMarketplaceCreatePublication(data) {
        return (
          data.publicationStatus == 'published'
          && data.keys().hasAll(['publishedAt'])
          && data.publishedAt == request.time
        ) || (
          data.publicationStatus in ['draft', 'paused']
          && !data.keys().hasAny(['publishedAt'])
        );
      }

      function preservesMarketplacePublishedAt() {
        return (
          !existing().keys().hasAny(['publishedAt'])
          && incoming().publicationStatus == 'published'
          && incoming().keys().hasAll(['publishedAt'])
          && incoming().publishedAt == request.time
        ) || (
          existing().keys().hasAny(['publishedAt'])
          && incoming().keys().hasAll(['publishedAt'])
          && incoming().publishedAt == existing().publishedAt
        ) || (
          !existing().keys().hasAny(['publishedAt'])
          && !incoming().keys().hasAny(['publishedAt'])
          && incoming().publicationStatus != 'published'
        );
      }

      function hasValidMarketplaceStoreUpdateFields() {
        return incoming()
          .diff(existing())
          .affectedKeys()
          .hasOnly([
            'name',
            'slug',
            'description',
            'address',
            'logo',
            'banner',
            'primaryColor',
            'keywords',
            'status',
            'publicationStatus',
            'publishedAt',
            'geoPosition',
            'updatedAt'
          ]);
      }

      function hasValidMarketplaceOfferUpdateFields() {
        return incoming()
          .diff(existing())
          .affectedKeys()
          .hasOnly([
            'name',
            'description',
            'price',
            'imageUrls',
            'stock',
            'isService',
            'category',
            'publicationStatus',
            'publishedAt',
            'updatedAt'
          ]);
      }

      function hasValidMarketplaceUpdateFields() {
        return (
          existing().listingType == 'store'
          && incoming().listingType == 'store'
          && hasValidMarketplaceStoreUpdateFields()
        ) || (
          existing().listingType == 'offer'
          && incoming().listingType == 'offer'
          && hasValidMarketplaceOfferUpdateFields()
        );
      }

      allow get: if existing().publicationStatus == 'published'
        || isMarketplaceListingOwner(existing());

      allow list: if existing().publicationStatus == 'published';

      allow create: if hasValidMarketplaceListingKeys(incoming())
        && hasValidMarketplaceListingTypes(incoming())
        && isMarketplaceListingOwner(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && hasValidMarketplaceCreatePublication(incoming());

      allow update: if hasValidMarketplaceListingKeys(incoming())
        && hasValidMarketplaceListingTypes(incoming())
        && isMarketplaceListingOwner(existing())
        && isMarketplaceListingOwner(incoming())
        && incoming().listingType == existing().listingType
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && preservesMarketplacePublishedAt()
        && hasValidMarketplaceUpdateFields();

      allow delete: if false;
    }
