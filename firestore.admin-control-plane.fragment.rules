    // --- Kyrub Administrative Control Plane ---
    function controlPlaneAdminDocument(userId) {
      return /databases/$(database)/documents/kyrub_admin/control_plane/admins/$(userId);
    }

    function hasControlPlaneAdminRecord() {
      return isSignedIn()
        && exists(controlPlaneAdminDocument(request.auth.uid));
    }

    function controlPlaneAdminRecord() {
      return get(controlPlaneAdminDocument(request.auth.uid)).data;
    }

    function isActiveControlPlaneAdmin() {
      return hasControlPlaneAdminRecord()
        && controlPlaneAdminRecord().uid == request.auth.uid
        && controlPlaneAdminRecord().status == 'active'
        && controlPlaneAdminRecord().role in [
          'super_admin',
          'support',
          'operations',
          'finance',
          'compliance'
        ];
    }

    function hasControlPlaneRole(roles) {
      return isActiveControlPlaneAdmin()
        && controlPlaneAdminRecord().role in roles;
    }

    function canReadControlPlaneDirectory() {
      return hasControlPlaneRole([
        'super_admin',
        'support',
        'operations',
        'compliance'
      ]);
    }

    match /kyrub_admin/control_plane {
      allow read, write: if false;

      match /admins/{adminId} {
        allow get: if isSignedIn() && (
          request.auth.uid == adminId
          || hasControlPlaneRole(['super_admin'])
        );
        allow list: if hasControlPlaneRole(['super_admin']);
        allow create, update, delete: if false;
      }

      match /audit_logs/{auditId} {
        function hasValidClientAuditTarget(data) {
          return (
            data.action == 'admin.session.accessed'
            && data.targetType == 'control_plane'
            && data.targetId == 'admin_portal'
          ) || (
            data.action == 'admin.directory.user.searched'
            && data.targetType == 'user'
            && isValidId(data.targetId)
          );
        }

        function hasValidClientAudit(data) {
          return isValidId(auditId)
            && data.keys().hasAll([
              'id',
              'action',
              'actorId',
              'actorRole',
              'targetType',
              'targetId',
              'source',
              'createdAt'
            ])
            && data.keys().hasOnly([
              'id',
              'action',
              'actorId',
              'actorRole',
              'targetType',
              'targetId',
              'source',
              'createdAt'
            ])
            && data.id == auditId
            && data.actorId == request.auth.uid
            && data.actorRole == controlPlaneAdminRecord().role
            && data.source == 'client'
            && data.createdAt == request.time
            && hasValidClientAuditTarget(data);
        }

        allow get, list: if hasControlPlaneRole(['super_admin', 'compliance']);
        allow create: if isActiveControlPlaneAdmin()
          && hasValidClientAudit(request.resource.data);
        allow update, delete: if false;
      }
    }

    // Read-only directory and aggregate access. Client code uses exact e-mail or
    // UID lookups and bounded membership queries; no mutation is granted here.
    match /users/{userId} {
      allow get, list: if canReadControlPlaneDirectory();
    }

    match /stores/{storeId} {
      allow get, list: if canReadControlPlaneDirectory();
    }

    match /tenants/{tenantId} {
      allow get, list: if canReadControlPlaneDirectory();
    }

    match /{path=**}/members/{memberId} {
      allow get: if canReadControlPlaneDirectory();
      allow list: if canReadControlPlaneDirectory()
        && request.query.limit != null
        && request.query.limit <= 100;
    }
