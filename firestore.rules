rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Otimizado: Verificação de papéis usando Custom Claims do Auth (sem custo de leitura de banco)
    function hasRole(roleList) { return isSignedIn() && request.auth.token.role in roleList; }
    function isAdmin() { return isSignedIn() && request.auth.token.role == 'admin'; }

    // --- Global User Directory ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
              && request.auth.uid == userId
              && incoming().keys().hasAll([
                'uid',
                'name',
                'email',
                'photoUrl',
                'isProfileVisible',
                'createdAt',
                'updatedAt'
              ])
              && incoming().keys().hasOnly([
                'uid',
                'name',
                'email',
                'photoUrl',
                'isProfileVisible',
                'createdAt',
                'updatedAt'
              ])
              && incoming().uid == userId
              && incoming().name is string
              && incoming().email is string
              && incoming().photoUrl is string
              && incoming().isProfileVisible is bool
              && incoming().createdAt == request.time
              && incoming().updatedAt == request.time;

			allow update: if isSignedIn()
              && request.auth.uid == userId
              && incoming().uid == existing().uid
              && incoming().createdAt == existing().createdAt
              && incoming().updatedAt == request.time
              && incoming().diff(existing()).affectedKeys().hasOnly([
                'name',
                'email',
                'photoUrl',
                'isProfileVisible',
                'updatedAt'
              ])
              && incoming().name is string
              && incoming().email is string
              && incoming().photoUrl is string
              && incoming().isProfileVisible is bool;

      // Coleção interna de Notas / Tarefas individuais e compartilhadas
      match /tasks/{taskId} {
        allow read: if isSignedIn() && (
          userId == request.auth.uid ||
          (resource != null && 'sharedWith' in resource.data && resource.data.sharedWith is list && request.auth.uid in resource.data.sharedWith)
        );
        allow create: if isSignedIn() && userId == request.auth.uid;
        allow update: if isSignedIn() && (
          userId == request.auth.uid ||
          (resource != null && 'sharedWith' in resource.data && resource.data.sharedWith is list && request.auth.uid in resource.data.sharedWith)
        );
        allow delete: if isSignedIn() && userId == request.auth.uid;
      }
      match /favorites/{favoriteId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /skills/{skillId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // --- Collection Group Match para permitir leitura de notas compartilhadas ---
    match /{path=**}/tasks/{taskId} {
      allow read: if isSignedIn() && (
        resource != null && 'sharedWith' in resource.data && resource.data.sharedWith is list && request.auth.uid in resource.data.sharedWith
      );
    }

    // --- Tenants (Store Directory) ---
    match /tenants/{tenantId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    // --- Tenant Artifacts (Multi-tenant) ---
    match /artifacts/{tenantId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();

      match /{allData=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- Kyrub Social Connections & Feed ---
match /connections/{connectionId} {
  function hasValidConnectionId() {
    return connectionId.size() > 0
      && connectionId.size() <= 128
      && connectionId.matches('^[a-zA-Z0-9_-]+$');
  }

  function hasValidParticipants(data) {
    return data.senderId is string
      && data.receiverId is string
      && data.senderId.size() > 0
      && data.senderId.size() <= 128
      && data.receiverId.size() > 0
      && data.receiverId.size() <= 128
      && data.senderId.matches('^[a-zA-Z0-9_-]+$')
      && data.receiverId.matches('^[a-zA-Z0-9_-]+$')
      && data.senderId != data.receiverId
      && data.participantIds is list
      && data.participantIds.size() == 2
      && data.participantIds.hasAll([
        data.senderId,
        data.receiverId
      ])
      && (
        connectionId == data.senderId + '_' + data.receiverId
        || connectionId == data.receiverId + '_' + data.senderId
      );
  }

  function hasImmutableParticipants() {
    return incoming().senderId == existing().senderId
      && incoming().receiverId == existing().receiverId
      && incoming().participantIds == existing().participantIds;
  }

  allow read: if isSignedIn()
    && (
      request.auth.uid in existing().participantIds
      || isAdmin()
    );

  allow create: if isSignedIn()
    && hasValidConnectionId()
    && hasValidParticipants(incoming())
    && incoming().senderId == request.auth.uid
    && incoming().status == 'pending'
    && incoming().createdAt == request.time
    && incoming().updatedAt == request.time
    && incoming().keys().hasAll([
      'senderId',
      'receiverId',
      'participantIds',
      'status',
      'createdAt',
      'updatedAt'
    ])
    && incoming().keys().hasOnly([
      'senderId',
      'receiverId',
      'participantIds',
      'status',
      'senderName',
      'senderRole',
      'senderAvatar',
      'senderBio',
      'receiverName',
      'receiverRole',
      'receiverAvatar',
      'receiverBio',
      'createdAt',
      'updatedAt'
    ]);

  allow update: if isSignedIn()
    && request.auth.uid == existing().receiverId
    && existing().status == 'pending'
    && incoming().status == 'accepted'
    && hasImmutableParticipants()
    && incoming().diff(existing()).affectedKeys().hasOnly([
  'status',
  'acceptedAt',
  'updatedAt'
])
    && incoming().createdAt == existing().createdAt
    && incoming().acceptedAt == request.time
    && incoming().updatedAt == request.time
    && incoming().keys().hasOnly([
      'senderId',
      'receiverId',
      'participantIds',
      'status',
      'senderName',
      'senderRole',
      'senderAvatar',
      'senderBio',
      'receiverName',
      'receiverRole',
      'receiverAvatar',
      'receiverBio',
      'createdAt',
      'acceptedAt',
      'updatedAt'
    ]);

  allow delete: if isSignedIn()
    && (
      isAdmin()
      || (
        existing().status == 'pending'
        && (
          request.auth.uid == existing().senderId
          || request.auth.uid == existing().receiverId
        )
      )
      || (
        existing().status == 'accepted'
        && request.auth.uid in existing().participantIds
      )
    );
}

    match /social_chats/{connectionId} {
      function connectionExists() {
        return exists(
          /databases/$(database)/documents/connections/$(connectionId)
        );
      }

      function connectionData() {
        return get(
          /databases/$(database)/documents/connections/$(connectionId)
        ).data;
      }

      function canAccessMessages() {
        return isSignedIn()
          && isValidId(connectionId)
          && connectionExists()
          && connectionData().status == 'accepted'
          && request.auth.uid in connectionData().participantIds;
      }

      function hasValidReceiver() {
        return (
          request.auth.uid == connectionData().senderId
          && incoming().receiverId == connectionData().receiverId
        ) || (
          request.auth.uid == connectionData().receiverId
          && incoming().receiverId == connectionData().senderId
        );
      }

      allow read, write: if false;

      match /messages/{messageId} {
        allow get: if canAccessMessages()
          && isValidId(messageId);

        allow list: if canAccessMessages()
          && request.query.limit <= 100;

        allow create: if canAccessMessages()
          && isValidId(messageId)
          && incoming().keys().hasAll([
            'senderId',
            'receiverId',
            'text',
            'createdAt'
          ])
          && incoming().keys().hasOnly([
            'senderId',
            'receiverId',
            'text',
            'createdAt'
          ])
          && incoming().senderId == request.auth.uid
          && isValidId(incoming().senderId)
          && isValidId(incoming().receiverId)
          && hasValidReceiver()
          && incoming().text is string
          && incoming().text.size() >= 1
          && incoming().text.size() <= 4000
          && incoming().createdAt == request.time;

        allow update: if false;
        allow delete: if false;
      }
    }

    // --- Reviews ---
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (existing().userId == request.auth.uid || incoming().keys().hasOnly(['likes']) || isAdmin());
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // --- Guia Renda: Entregas Solicitadas/Disponíveis ---
    match /hub/renda/deliveries/{deliveryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Qualquer usuário ou lojista logado pode solicitar
      allow update, delete: if isSignedIn();
    }

    // --- Guia Renda: Vagas de Freela (Otimizado com Custom Claims) ---
    match /vagas/{vagaId} {
      allow read: if isSignedIn();
      // Apenas contratantes (owner, manager, staff) ou admin podem criar e gerenciar vagas
      allow create, update, delete: if isAdmin() || hasRole(['owner', 'manager', 'staff']);
    }

    // --- Candidaturas (Prestar o serviço de Freela) ---
    match /candidaturas/{candiId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn();
    }

    match /artifacts { allow list: if isSignedIn(); }
    match /tenants { allow list: if isSignedIn(); }
  }
}
