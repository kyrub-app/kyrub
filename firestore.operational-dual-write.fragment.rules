    // --- Operational Orders and Payments Dual Write ---
    function operationalMirrorMetadataIsValid(storeId) {
      return storeSecOwner(storeId)
        && incoming().migration.mode == 'dual_write'
        && incoming().migration.migratedByUserId == request.auth.uid
        && incoming().migration.migratedByRole == 'owner'
        && incoming().legacyStoreId is string
        && incoming().legacyStoreId != storeId
        && incoming().migratedFromPath is string;
    }

    function operationalMirroredOrderActorIsValid() {
      return (
          incoming().source == 'customer'
          && incoming().createdByUserId == incoming().buyerId
          && incoming().createdByRole == 'customer'
        )
        || (
          (incoming().source == 'staff' || incoming().source == 'transfer')
          && incoming().createdByUserId == request.auth.uid
          && incoming().createdByRole == 'owner'
        );
    }
